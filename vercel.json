{
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@5.7.12"
    }
  },
  "buildCommand": "npm run build",
  "framework": "vite",
  "installCommand": "npm install --legacy-peer-deps",
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
